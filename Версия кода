#include <iostream>
using namespace std;

class Room
{
private:
    int Number;          // номер комнаты
    int Count;           // количество мест
    double Price;        // цена за ночь
    int CountOccupied;   // занято мест

public:
    // конструктор по умолчанию
    Room()
    {
        Number = 0;
        Count = 1;
        Price = 0;
        CountOccupied = 0;
    }

    // конструктор с параметрами
    Room(int m_Number, int m_Count, double m_Price, int m_CountOccupied)
    {
        Number = m_Number;

        if (m_Count > 0)
            Count = m_Count;
        else
        {
            cout << "Некорректное количество мест" << endl;
            Count = 1;
        }

        if (m_Price >= 0)
            Price = m_Price;
        else
        {
            cout << "Некорректная цена" << endl;
            Price = 0;
        }

        if (m_CountOccupied >= 0 && m_CountOccupied <= Count)
            CountOccupied = m_CountOccupied;
        else
        {
            cout << "Некорректное количество занятых мест" << endl;
            CountOccupied = 0;
        }
    }

    // деструктор
    ~Room()
    {
        cout << "Комната " << Number << " удалена" << endl;
    }

    // вывод информации
    void printInfo()
    {
        cout << "Номер комнаты: " << Number << endl;
        cout << "Количество мест: " << Count << endl;
        cout << "Цена за ночь: " << Price << endl;
        cout << "Занято мест: " << CountOccupied << endl;
        cout << "----------------" << endl;
    }

    // геттеры
    int getNumber() const 
    { 
        return Number;
    }
    int getCount() const 
    { 
        return Count; 
    }
    double getPrice() const 
    { 
        return Price; 
    }
    int getCountOccupied() const 
    { 
        return CountOccupied; 
    }

    // сеттеры
    void setPrice(double new_Price)
    {
        if (new_Price >= 0)
            Price = new_Price;
        else
            cout << "Цена не может быть отрицательной" << endl;
    }

    void setCount(int new_Count)
    {
        if (new_Count > 0)
            Count = new_Count;
        else
            cout << "Количество мест должно быть > 0" << endl;
    }

    // заселение
    void checkIn()
    {
        if (CountOccupied < Count)
        {
            CountOccupied= CountOccupied +1;
            cout << "Гость заселен. Занято: " << CountOccupied << endl;
        }
        else
            cout << "Нет свободных мест" << endl;
    }

    // выселение
    void checkOut()
    {
        if (CountOccupied > 0)
        {
            CountOccupied= CountOccupied -1;
            cout << "Гость выселен. Занято: " << CountOccupied << endl;
        }
        else
            cout << "Комната уже пустая" << endl;
    }

    // расчет стоимости
    void Cost(int Nights)
    {
        if (Nights <= 0)
        {
            cout << "Некорректное количество ночей" << endl;
            return;
        }

        cout << "Стоимость: " << Price * Nights << endl;
    }
};

int main()
{
    setlocale(LC_ALL, "RU");

    Room room1;
    room1.printInfo();

    Room room2(22, 3, 3500, 2);
    room2.printInfo();

    room2.checkIn();
    room2.checkOut();
    room2.Cost(3);

    room2.setPrice(4000);
    room2.setCount(5);


    room2.setPrice(-1000);   // ошибка
    room2.setCount(-2);      // ошибка
    return 0;
}
